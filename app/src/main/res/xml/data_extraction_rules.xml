<?xml version="1.0" encoding="utf-8"?>
<!-- Singventory data extraction rules for Android 12+ backup system -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include user data for cloud backup and GDPR data portability -->
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
        
        <!-- Exclude sensitive analytics data -->
        <exclude domain="sharedpref" path="firebase_analytics.xml"/>
        <exclude domain="sharedpref" path="device_id.xml"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- Include all user data for device transfers -->
        <include domain="database" path="."/>
        <include domain="sharedpref" path="."/>
        
        <!-- Exclude analytics data from device transfers -->
        <exclude domain="sharedpref" path="firebase_analytics.xml"/>
    </device-transfer>
</data-extraction-rules>