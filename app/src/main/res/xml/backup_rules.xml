<?xml version="1.0" encoding="utf-8"?>
<!-- Singventory backup rules for user data protection and GDPR compliance -->
<full-backup-content>
    <!-- Include user preferences and database for backup -->
    <include domain="sharedpref" path="."/>
    <include domain="database" path="."/>
    
    <!-- Exclude sensitive analytics data -->
    <exclude domain="sharedpref" path="firebase_analytics.xml"/>
    <exclude domain="sharedpref" path="device_analytics.xml"/>
</full-backup-content>